# === AI Provider ===
# MWS GPT API — the single upstream for all chat, vision, embeddings, STT and
# image-generation models. See litellm/config.yaml for the 26 available aliases.
# https://api.gpt.mws.ru/v1
MWS_GPT_API_KEY=sk-...

# === LiteLLM ===
# If left empty, docker-compose.yml provides a dev-only default. For prod, set
# to a random value: openssl rand -hex 32
LITELLM_MASTER_KEY=

# === OpenWebUI ===
# If left empty, docker-compose.yml provides a dev-only default. For prod:
# openssl rand -hex 32
OPENWEBUI_SECRET_KEY=

# Required for phase-11 pptx delivery. Auto-provisioned by the bootstrap
# sidecar after the first admin signup — leave empty on first boot.
OWUI_ADMIN_TOKEN=
OWUI_BASE_URL=http://localhost:3000

# === PostgreSQL ===
POSTGRES_USER=mws
# If left empty, docker-compose.yml provides a dev-only default. For prod:
# openssl rand -hex 16
POSTGRES_PASSWORD=
POSTGRES_DB=openwebui

# === Langfuse (Phase 2) ===
# Created in the Langfuse UI on first visit; tracing is disabled until set.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
# Dev defaults in docker-compose.yml. For prod: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=

# === Fact-checker (Phase 12) ===
# The fact-checker subagent (_sa_fact_check in pipelines/auto_router_function.py)
# requires NO new environment variables. All tunables live on the Pipe's Valves
# (OpenWebUI → Admin → Functions → MWS GPT Auto 🎯 → Valves): fact_check_enabled,
# fact_check_timeout, fact_check_max_urls, fact_check_max_claims, fact_check_model
# (default mws/kimi-k2), fact_check_claim_model (default mws/gpt-oss-20b). The
# claim extractor and verdict LLM both go through LiteLLM, so MWS_GPT_API_KEY
# above is the only secret required to make them work.
