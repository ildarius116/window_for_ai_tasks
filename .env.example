# === AI Provider ===
# MWS GPT API — the single upstream for all chat, vision, embeddings, STT and
# image-generation models. See litellm/config.yaml for the 26 available aliases.
MWS_GPT_API_KEY=sk-...            # https://api.gpt.mws.ru/v1

# === LiteLLM ===
LITELLM_MASTER_KEY=   # openssl rand -hex 32

# === OpenWebUI ===
OPENWEBUI_SECRET_KEY=  # openssl rand -hex 32

# Required for phase-11 pptx delivery: auto-router Pipe uses this token to
# upload generated .pptx files via POST /api/v1/files/ so the chat can link
# to them. Also used by the manual `make deploy-functions` escape hatch.
# Without it, _sa_presentation falls back to a markdown slide plan.
OWUI_ADMIN_TOKEN=
OWUI_BASE_URL=http://localhost:3000

# === PostgreSQL ===
POSTGRES_USER=mws
POSTGRES_PASSWORD=     # openssl rand -hex 16
POSTGRES_DB=openwebui

# === Langfuse (Phase 2) ===
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_NEXTAUTH_SECRET=  # openssl rand -hex 32
LANGFUSE_SALT=             # openssl rand -hex 32
